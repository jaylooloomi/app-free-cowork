{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FreeCowork",
  "version": "0.1.0",
  "identifier": "com.jaylooloomi.free-claude-code",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "palette",
        "title": "FreeCowork",
        "theme": "Dark",
        "width": 640,
        "height": 168,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": false
      },
      {
        "label": "wizard",
        "title": "FreeCowork 首次設定",
        "width": 560,
        "height": 540,
        "visible": false,
        "resizable": false
      },
      {
        "label": "settings",
        "title": "FreeCowork 設定",
        "width": 560,
        "height": 600,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["icons/128x128.png", "icons/icon.ico"],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["TradChinese", "English"]
      }
    }
  }
}
