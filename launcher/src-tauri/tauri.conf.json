{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Free Claude Code",
  "version": "0.1.0",
  "identifier": "com.jaylooloomi.free-claude-code",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "palette",
        "title": "Free Claude Code",
        "width": 640,
        "height": 168,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": false
      },
      {
        "label": "wizard",
        "title": "Free Claude Code 首次設定",
        "width": 560,
        "height": 540,
        "visible": false,
        "resizable": false
      },
      {
        "label": "settings",
        "title": "Free Claude Code 設定",
        "width": 560,
        "height": 600,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
